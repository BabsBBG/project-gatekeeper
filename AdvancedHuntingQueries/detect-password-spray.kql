EntraIdSignInEvents
| where Timestamp > ago(1h)
| where ErrorCode in (50053, 50056, 50126)
| summarize FailedAttempts = count(), TargetedUsers = dcount(AccountUpn), UserList = make_set(AccountUpn, 10) by IPAddress, bin(Timestamp, 5m)
| where TargetedUsers >= 5 and FailedAttempts >= 10
| extend ThreatType = "Password Spray Detected"
| project Timestamp = bin(Timestamp, 5m), IPAddress, TargetedUsers, FailedAttempts, UserList, ThreatType
